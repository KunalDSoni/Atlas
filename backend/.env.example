# ===== ATLAS CONFIGURATION =====
# Copy this file to .env and edit values

# ---------- Environment ----------
NODE_ENV=development
PORT=3001

# ---------- Database ----------
# "sqlite" for local dev, "postgres" for production
DB_DRIVER=sqlite

# SQLite (local dev only)
SQLITE_PATH=./data.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@host:5432/atlas_db

# ---------- Auth ----------
# Set a real secret for production (used for session tokens)
SESSION_SECRET=change-me-in-production
# Session expiry in days
SESSION_EXPIRY_DAYS=7

# ---------- Seed Data ----------
# Set to "true" to populate demo data on first run
# Set to "false" for a clean empty database (real data)
SEED_DEMO_DATA=true

# ---------- Admin Account ----------
# Created on first run when SEED_DEMO_DATA=false
ADMIN_NAME=Kunal Soni
ADMIN_EMAIL=admin@atlas.local
ADMIN_PASSWORD=changeme123
