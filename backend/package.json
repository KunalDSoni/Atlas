{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest --verbose --forceExit --detectOpenHandles --runInBand",
    "test:coverage": "jest --verbose --forceExit --detectOpenHandles --coverage",
    "test:backend": "jest --verbose --forceExit --detectOpenHandles --testPathPattern=tests/backend",
    "test:frontend": "jest --verbose --forceExit --detectOpenHandles --testPathPattern=tests/frontend"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ],
    "transform": {
      "\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                }
              }
            ]
          ]
        }
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
