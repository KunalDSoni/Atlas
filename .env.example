# ===== Atlas Environment Configuration =====
# Copy this file to .env and update the values

# Application
NODE_ENV=production
PORT=3001
SESSION_SECRET=change-this-to-a-random-64-char-string

# Nginx ports (host mapping)
NGINX_PORT=80
NGINX_SSL_PORT=443

# Database (SQLite — file stored in Docker volume)
DATA_DIR=/app/data
